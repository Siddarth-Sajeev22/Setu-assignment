{
  "info": {
    "name": "Payment Events Service",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/health",
            "description": "Verifies the service and database are up."
          }
        }
      ]
    },
    {
      "name": "Events",
      "item": [
        {
          "name": "Ingest Event — payment_initiated",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/events",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"event_id\": \"evt-0001-0000-0000-000000000001\",\n  \"transaction_id\": \"txn-0001-0000-0000-000000000001\",\n  \"merchant_id\": \"MER001\",\n  \"merchant_name\": \"Acme Corp\",\n  \"event_type\": \"payment_initiated\",\n  \"amount\": \"500.00\",\n  \"currency\": \"INR\",\n  \"timestamp\": \"2026-01-08T10:00:00Z\"\n}"
            },
            "description": "Creates a new transaction in 'initiated' status. Returns 201 on success, 200 if event_id already exists."
          }
        },
        {
          "name": "Ingest Event — payment_processed",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/events",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"event_id\": \"evt-0001-0000-0000-000000000002\",\n  \"transaction_id\": \"txn-0001-0000-0000-000000000001\",\n  \"merchant_id\": \"MER001\",\n  \"merchant_name\": \"Acme Corp\",\n  \"event_type\": \"payment_processed\",\n  \"amount\": \"500.00\",\n  \"currency\": \"INR\",\n  \"timestamp\": \"2026-01-08T10:01:00Z\"\n}"
            },
            "description": "Advances the same transaction to 'processed'. Must use the same transaction_id."
          }
        },
        {
          "name": "Ingest Event — settled",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/events",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"event_id\": \"evt-0001-0000-0000-000000000003\",\n  \"transaction_id\": \"txn-0001-0000-0000-000000000001\",\n  \"merchant_id\": \"MER001\",\n  \"merchant_name\": \"Acme Corp\",\n  \"event_type\": \"settled\",\n  \"amount\": \"500.00\",\n  \"currency\": \"INR\",\n  \"timestamp\": \"2026-01-08T10:02:00Z\"\n}"
            },
            "description": "Settles the transaction. Terminal state — no further events allowed."
          }
        },
        {
          "name": "Ingest Event — payment_failed",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/events",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"event_id\": \"evt-0002-0000-0000-000000000001\",\n  \"transaction_id\": \"txn-0002-0000-0000-000000000001\",\n  \"merchant_id\": \"MER002\",\n  \"merchant_name\": \"Globex Ltd\",\n  \"event_type\": \"payment_initiated\",\n  \"amount\": \"250.00\",\n  \"currency\": \"USD\",\n  \"timestamp\": \"2026-01-08T11:00:00Z\"\n}"
            },
            "description": "Initiates a second transaction that will be failed in the next request."
          }
        },
        {
          "name": "Ingest Event — duplicate (idempotency check)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/events",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"event_id\": \"evt-0001-0000-0000-000000000001\",\n  \"transaction_id\": \"txn-0001-0000-0000-000000000001\",\n  \"merchant_id\": \"MER001\",\n  \"merchant_name\": \"Acme Corp\",\n  \"event_type\": \"payment_initiated\",\n  \"amount\": \"500.00\",\n  \"currency\": \"INR\",\n  \"timestamp\": \"2026-01-08T10:00:00Z\"\n}"
            },
            "description": "Same event_id as the first request. Should return 200 (not 201) without creating a duplicate."
          }
        }
      ]
    },
    {
      "name": "Transactions",
      "item": [
        {
          "name": "List Transactions",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/transactions",
              "host": ["{{base_url}}"],
              "path": ["transactions"]
            },
            "description": "Returns paginated list of all transactions with their events."
          }
        },
        {
          "name": "List Transactions — filter by merchant",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/transactions?merchant_id=MER001",
              "host": ["{{base_url}}"],
              "path": ["transactions"],
              "query": [
                { "key": "merchant_id", "value": "MER001" }
              ]
            }
          }
        },
        {
          "name": "List Transactions — filter by status",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/transactions?status=settled",
              "host": ["{{base_url}}"],
              "path": ["transactions"],
              "query": [
                { "key": "status", "value": "settled" }
              ]
            },
            "description": "Valid statuses: initiated, processed, failed, settled"
          }
        },
        {
          "name": "List Transactions — filter by date range",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/transactions?start_date=2026-01-01T00:00:00Z&end_date=2026-01-31T23:59:59Z",
              "host": ["{{base_url}}"],
              "path": ["transactions"],
              "query": [
                { "key": "start_date", "value": "2026-01-01T00:00:00Z" },
                { "key": "end_date",   "value": "2026-01-31T23:59:59Z" }
              ]
            }
          }
        },
        {
          "name": "List Transactions — paginated & sorted",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/transactions?page=1&limit=20&sort_by=amount&order=desc",
              "host": ["{{base_url}}"],
              "path": ["transactions"],
              "query": [
                { "key": "page",    "value": "1" },
                { "key": "limit",   "value": "20" },
                { "key": "sort_by", "value": "amount", "description": "created_at | amount | merchant_id" },
                { "key": "order",   "value": "desc",   "description": "asc | desc" }
              ]
            }
          }
        },
        {
          "name": "Get Transaction by ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/transactions/txn-0001-0000-0000-000000000001",
              "host": ["{{base_url}}"],
              "path": ["transactions", "txn-0001-0000-0000-000000000001"]
            },
            "description": "Returns full transaction details including complete event history."
          }
        },
        {
          "name": "Get Transaction by ID — not found",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/transactions/txn-does-not-exist",
              "host": ["{{base_url}}"],
              "path": ["transactions", "txn-does-not-exist"]
            },
            "description": "Should return 404."
          }
        }
      ]
    },
    {
      "name": "Reconciliation",
      "item": [
        {
          "name": "Summary — group by merchant",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/reconciliation/summary?group_by=merchant",
              "host": ["{{base_url}}"],
              "path": ["reconciliation", "summary"],
              "query": [
                { "key": "group_by", "value": "merchant" }
              ]
            },
            "description": "Transaction count and total amount per merchant."
          }
        },
        {
          "name": "Summary — group by date",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/reconciliation/summary?group_by=date",
              "host": ["{{base_url}}"],
              "path": ["reconciliation", "summary"],
              "query": [
                { "key": "group_by", "value": "date" }
              ]
            }
          }
        },
        {
          "name": "Summary — group by status",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/reconciliation/summary?group_by=status",
              "host": ["{{base_url}}"],
              "path": ["reconciliation", "summary"],
              "query": [
                { "key": "group_by", "value": "status" }
              ]
            }
          }
        },
        {
          "name": "Summary — overall (all)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/reconciliation/summary?group_by=all",
              "host": ["{{base_url}}"],
              "path": ["reconciliation", "summary"],
              "query": [
                { "key": "group_by", "value": "all" }
              ]
            }
          }
        },
        {
          "name": "Summary — filtered by merchant + date range",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/reconciliation/summary?group_by=merchant&merchant_id=MER001&start_date=2026-01-01T00:00:00Z&end_date=2026-01-31T23:59:59Z",
              "host": ["{{base_url}}"],
              "path": ["reconciliation", "summary"],
              "query": [
                { "key": "group_by",   "value": "merchant" },
                { "key": "merchant_id","value": "MER001" },
                { "key": "start_date", "value": "2026-01-01T00:00:00Z" },
                { "key": "end_date",   "value": "2026-01-31T23:59:59Z" }
              ]
            }
          }
        },
        {
          "name": "Discrepancies",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/reconciliation/discrepancies",
              "host": ["{{base_url}}"],
              "path": ["reconciliation", "discrepancies"]
            },
            "description": "Returns transactions with discrepancies: processed_not_settled, settled_after_failed, duplicate_initiated."
          }
        },
        {
          "name": "Discrepancies — paginated",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/reconciliation/discrepancies?page=1&limit=20",
              "host": ["{{base_url}}"],
              "path": ["reconciliation", "discrepancies"],
              "query": [
                { "key": "page",  "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            }
          }
        }
      ]
    }
  ]
}
