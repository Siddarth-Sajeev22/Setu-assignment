    {
      "name": "Events",
      "item": [
        {
          "name": "Ingest Event — payment_initiated",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"event_id\": \"fc53feb8-b5e5-123a-ab7b-23344371f123\",\n  \"transaction_id\": \"fce50187-f1ef-58e3-9d28-45610f17a3ea\",\n  \"merchant_id\": \"merchant_190\",\n  \"merchant_name\": \"Acmejddj Corp\",\n  \"event_type\": \"payment_initiated\",\n  \"amount\": \"500.00\",\n  \"currency\": \"INR\",\n  \"timestamp\": \"2026-01-08T10:00:00Z\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/events",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "events"
              ]
            },
            "description": "Creates a new transaction in 'initiated' status. Returns 201 on success, 200 if event_id already exists."
          },
          "response": []
        },
        {
          "name": "Ingest Event — payment_processed",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"event_id\": \"fc53feb8-b5e5-456a-ab7b-23344371f123\",\n  \"transaction_id\": \"fce50187-f1ef-58e3-9d28-45610f17a3ea\",\n  \"merchant_id\": \"merchant_190\",\n  \"merchant_name\": \"Acmejddj Corp\",\n  \"event_type\": \"payment_processed\",\n  \"amount\": \"500.00\",\n  \"currency\": \"INR\",\n  \"timestamp\": \"2026-01-08T10:00:00Z\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/events",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "events"
              ]
            },
            "description": "Advances the same transaction to 'processed'. Must use the same transaction_id."
          },
          "response": []
        },
        {
          "name": "Ingest Event — settled",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"event_id\": \"fc53feb8-b5e5-321a-ab7b-23344371f123\",\n  \"transaction_id\": \"fce50187-f1ef-58e3-9d28-45610f17a3ea\",\n  \"merchant_id\": \"merchant_190\",\n  \"merchant_name\": \"Acmejddj Corp\",\n  \"event_type\": \"settled\",\n  \"amount\": \"500.00\",\n  \"currency\": \"INR\",\n  \"timestamp\": \"2026-01-08T10:00:00Z\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/events",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "events"
              ]
            },
            "description": "Settles the transaction. Terminal state — no further events allowed."
          },
          "response": []
        },
        {
          "name": "Ingest Event — duplicate (idempotency check)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"event_id\": \"fc53feb8-b5e5-123a-ab7b-23344371f123\",\n  \"transaction_id\": \"fce50187-f1ef-58e3-9d28-45610f17a3ea\",\n  \"merchant_id\": \"merchant_190\",\n  \"merchant_name\": \"Acmejddj Corp\",\n  \"event_type\": \"payment_initiated\",\n  \"amount\": \"500.00\",\n  \"currency\": \"INR\",\n  \"timestamp\": \"2026-01-08T10:00:00Z\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/events",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "events"
              ]
            },
            "description": "Same event_id as the first request. Should return 200 (not 201) without creating a duplicate."
          },
          "response": []
        }
      ]
